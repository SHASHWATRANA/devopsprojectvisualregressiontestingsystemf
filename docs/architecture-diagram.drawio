        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#e67e22;strokeWidth=1.5;endArrow=blockThin;endFill=1;dashed=1;" edge="1" source="result_mgr" target="results_json" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Selenium to Target Website -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#e74c3c;strokeWidth=2;endArrow=blockThin;endFill=1;fontSize=9;fontFamily=Inter;" edge="1" source="selenium" target="target_web" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="350" y="630" />
              <mxPoint x="350" y="740" />
              <mxPoint x="385" y="740" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e11_label" value="HTTP / Screenshot" style="edgeLabel;html=1;fontSize=9;fontFamily=Inter;fontColor=#e74c3c;" vertex="1" connectable="0" parent="e11">
          <mxGeometry x="0.3" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- CI/CD to Presentation Layer -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8e44ad;strokeWidth=1.5;endArrow=blockThin;endFill=1;dashed=1;fontSize=9;fontFamily=Inter;" edge="1" source="gh_actions" target="pres_layer" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12_label" value="triggers" style="edgeLabel;html=1;fontSize=9;fontFamily=Inter;fontColor=#8e44ad;" vertex="1" connectable="0" parent="e12">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Docker wraps all -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8e44ad;strokeWidth=1.5;endArrow=blockThin;endFill=1;dashed=1;fontSize=9;fontFamily=Inter;" edge="1" source="docker" target="engine_layer" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13_label" value="containerises" style="edgeLabel;html=1;fontSize=9;fontFamily=Inter;fontColor=#8e44ad;" vertex="1" connectable="0" parent="e13">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Render deploys -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8e44ad;strokeWidth=1.5;endArrow=blockThin;endFill=1;dashed=1;fontSize=9;fontFamily=Inter;" edge="1" source="render" target="storage_layer" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14_label" value="deploys" style="edgeLabel;html=1;fontSize=9;fontFamily=Inter;fontColor=#8e44ad;" vertex="1" connectable="0" parent="e14">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- REST API to Result Manager (data feed) -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#27ae60;strokeWidth=1.5;endArrow=blockThin;endFill=1;" edge="1" source="rest_api" target="result_mgr" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GH Actions to Jenkins -->
        <mxCell id="e16" style="rounded=1;strokeColor=#8e44ad;strokeWidth=1;dashed=1;" edge="1" source="gh_actions" target="jenkins" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Jenkins to Docker -->
        <mxCell id="e17" style="rounded=1;strokeColor=#8e44ad;strokeWidth=1;dashed=1;" edge="1" source="jenkins" target="docker" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Docker to Render -->
        <mxCell id="e18" style="rounded=1;strokeColor=#8e44ad;strokeWidth=1;dashed=1;" edge="1" source="docker" target="render" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
